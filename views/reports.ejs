<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Relatórios - Slowtek Counter</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
</head>
<body>
    <%- include('partials/navbar') %>

    <div class="container-fluid py-4">
        <div class="row">
            <div class="col-12">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h2><i class="fas fa-file-alt me-2"></i>Relatórios de Denúncia</h2>
                    <button class="btn btn-primary" onclick="showReportModal()">
                        <i class="fas fa-plus me-2"></i>Novo Relatório
                    </button>
                </div>
            </div>
        </div>

        <% if (reports.length === 0) { %>
            <div class="row">
                <div class="col-12">
                    <div class="card">
                        <div class="card-body text-center py-5">
                            <i class="fas fa-file-alt fa-3x text-muted mb-3"></i>
                            <h5 class="text-muted">Nenhum relatório encontrado</h5>
                            <p class="text-muted">Clique em "Novo Relatório" para criar o primeiro relatório.</p>
                        </div>
                    </div>
                </div>
            </div>
        <% } else { %>
            <div class="row">
                <% reports.forEach(function(report, index) { %>
                    <div class="col-lg-6 mb-4">
                        <div class="card h-100">
                            <div class="card-header d-flex justify-content-between align-items-center">
                                <h6 class="mb-0">
                                    <i class="fas fa-hashtag me-1"></i>Relatório #<%= report.id %>
                                </h6>
                                <small class="text-muted">
                                    <%= new Date(report.createdAt).toLocaleDateString('pt-BR') %>
                                    <%= new Date(report.createdAt).toLocaleTimeString('pt-BR') %>
                                </small>
                            </div>
                            <div class="card-body">
                                <div class="row mb-3">
                                    <div class="col-sm-6">
                                        <strong>Denunciado:</strong><br>
                                        <span class="text-primary"><%= report.idDenunciado %></span>
                                    </div>
                                    <div class="col-sm-6">
                                        <strong>Ticket:</strong><br>
                                        <span class="text-info"><%= report.nomeTicket %></span>
                                    </div>
                                </div>
                                
                                <div class="mb-3">
                                    <strong>Motivo:</strong><br>
                                    <p class="text-muted mb-1"><%= report.motivo %></p>
                                </div>
                                
                                <div class="row mb-3">
                                    <div class="col-sm-6">
                                        <strong>ADV Aplicado:</strong><br>
                                        <span class="badge bg-warning text-dark"><%= report.adv %> ADV</span>
                                    </div>
                                    <div class="col-sm-6">
                                        <strong>Criado por:</strong><br>
                                        <span class="text-success"><%= report.createdBy %></span>
                                    </div>
                                </div>
                                
                                <div class="mb-0">
                                    <strong>Link:</strong><br>
                                    <a href="<%= report.link %>" target="_blank" class="btn btn-sm btn-outline-primary">
                                        <i class="fas fa-external-link-alt me-1"></i>Abrir Medal
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }); %>
            </div>
        <% } %>
    </div>

    <!-- Report Modal -->
    <div class="modal fade" id="reportModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="fas fa-file-alt me-2"></i>Registrar Relatório de Denúncia
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form id="reportForm">
                    <div class="modal-body">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="idDenunciado" class="form-label">ID do Denunciado</label>
                                <input type="text" class="form-control" id="idDenunciado" name="idDenunciado" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="nomeTicket" class="form-label">Nome do Ticket</label>
                                <input type="text" class="form-control" id="nomeTicket" name="nomeTicket" required>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label for="motivo" class="form-label">Motivo</label>
                            <textarea class="form-control" id="motivo" name="motivo" rows="3" required></textarea>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="adv" class="form-label">Quantidade de ADVs</label>
                                <input type="text" class="form-control" id="adv" name="adv" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="link" class="form-label">Link do Medal</label>
                                <input type="url" class="form-control" id="link" name="link" required>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save me-2"></i>Salvar Relatório
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/reports.js"></script>
</body>
</html>